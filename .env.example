# Copy to `.env` and fill in values. `.env` is gitignored.

# Postgres (used by the db service and by the app's DATABASE_URL below)
POSTGRES_USER=barchart
POSTGRES_PASSWORD=barchart
POSTGRES_DB=barchart

# App → database. Host defaults to `db` (the compose service name).
DATABASE_URL=postgresql+asyncpg://barchart:barchart@db:5432/barchart

# App → redis. Host defaults to `redis` (the compose service name).
REDIS_URL=redis://redis:6379/0

# 7 days
SESSION_TTL_SECONDS=604800

# How often the Barchart sync loop runs
SYNC_INTERVAL_SECONDS=3600
